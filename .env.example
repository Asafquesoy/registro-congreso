# Puerto del servidor
PORT=3000

# Secreto para las sesiones (CAMBIAR en produccion - usar un string largo y aleatorio)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=tu-secreto-seguro-aqui

# Entorno
NODE_ENV=production

# Zoho Mail (para envio de credenciales de usuarios del sistema)
ZOHO_EMAIL=tu-correo@zoho.com
